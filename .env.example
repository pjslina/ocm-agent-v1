# MasterAgent 本地启动环境变量模板。
# 用法：cp .env.example .env，按本机环境改值后 `python -m ma.main`（或 `python src/ma/main.py`）。
# main.py 仅在直接运行时读取 .env；被 import（测试 / uvicorn ma.main:app）时不读。
#
# 约定：可选项留空即等于“未设置”。对 Optional 字段（DB DSN / MetaGC / LLM key 等），
# 不需要时保持注释即可——留空值会被当作空字符串而非 None，可能触发非预期行为。

# ── 基础 ─────────────────────────
MA_ENV=dev
MA_LOG_LEVEL=info

# ── 可观测性 ──────────────────────
# OTLP gRPC endpoint，留空则 trace 仅在内存中（本地验迹见 README “Jaeger” 一节）
# MA_OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
MA_OTEL_SERVICE_NAME=master-agent

# ── DB (OpenGauss / PG-compatible) ───
# 必填（生产）。本地无 DB 时保持注释 → 服务以 smoke 模式启动（ChatService 为 None，transport 回 503）
# MA_PG_DSN_RW=postgresql://ma:ma@localhost:5432/ma
# 留空 → 读用同一个 RW DSN
# MA_PG_DSN_RO=
MA_PG_POOL_MIN=4
MA_PG_POOL_MAX=32

# ── 配置文件目录 ──────────────────
MA_CONFIG_TOPICS_DIR=config/topics
MA_SQL_TEMPLATES_DIR=sql

# ── LLM (intent) ─────────────────
# M1 用 fake；真 LLM 推到 M3。切到 openai-compatible 时需填 base_url / api_key
MA_INTENT_LLM_PROVIDER=fake
MA_INTENT_LLM_MODEL=fake-model
# MA_INTENT_LLM_BASE_URL=https://api.example.com/v1
# MA_INTENT_LLM_API_KEY=sk-xxx
# provider=openai-compatible 且 MA_INTENT_LLM_API_KEY 未设时回退读取此变量
# OPENAI_API_KEY=sk-xxx

# ── MetaGC 下游 ───────────────────
# 必填（生产）。本地可用 mock server（见 tests/mock_downstreams/metagc_sse.py）。
# 注意：topic YAML 经 ${env:...} 引用，留空也必须保留该变量（否则启动期编译 topic 报错）。
MA_METAGC_BASE_URL=
MA_METAGC_TIMEOUT_MS=30000

# ── 专题 YAML 引用（${env:...}，不经 Settings，仅经 os.environ）──
# 同上：留空也必须保留变量，否则 topic 编译期 KeyError。
MA_UNIIOC_BASE_URL=
MA_KC_WS_URL=

# ── AuthN（M0 占位）───────────────
MA_AUTHN_MODE=trust_header
MA_AUTHN_TRUST_HEADER_NAME=X-User-Account
